{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vmlab instance",
  "type": "object",
  "required": ["provider"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "provider": {
      "type": "string",
      "enum": ["parallels", "hetzner", "azure", "aws", "gcp", "tart", "windows"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "ready": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^(parallels-tools|ssh|tcp:[0-9]+|http)$"
        },
        "timeout": {
          "type": "string",
          "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h)$"
        }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "properties": {
        "transport": {
          "type": "string",
          "enum": ["local", "crabbox", "abx", "guiport", "adb", "idb", "simctl", "maestro", "parallels-guest", "ssh", "ssh-windows"]
        }
      },
      "additionalProperties": false
    },
    "disposition": {
      "type": "object",
      "properties": {
        "on_success": { "type": "string", "enum": ["keep", "suspend", "poweroff", "destroy"] },
        "on_failure": { "type": "string", "enum": ["keep", "suspend", "poweroff", "destroy"] },
        "only_if_we_started": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "budget": {
      "type": "object",
      "description": "Soft cost ceiling vmlab enforces before Up. Providers that implement Priced compare their own hourly rate against hourlyUSD; if exceeded, Up returns ErrBudgetExceeded.",
      "properties": {
        "hourlyUSD": { "type": "number", "minimum": 0 },
        "dailyUSD": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "mounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["host"],
        "properties": {
          "name":  { "type": "string", "minLength": 1 },
          "host":  { "type": "string", "minLength": 1 },
          "guest": { "type": "string" },
          "mode":  { "type": "string", "enum": ["ro", "rw"] },
          "from_laptop": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "hooks": {
      "type": "object",
      "properties": {
        "pre_up":   { "$ref": "#/$defs/hookList" },
        "post_up":  { "$ref": "#/$defs/hookList" },
        "pre_down": { "$ref": "#/$defs/hookList" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true,
  "$defs": {
    "hookList": {
      "type": "array",
      "items": { "$ref": "#/$defs/hookStep" }
    },
    "hookStep": {
      "type": "object",
      "properties": {
        "name":        { "type": "string" },
        "run":         { "type": "string" },
        "exec":        { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "target":      { "type": "string" },
        "target_exec": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "ignore_failure": { "type": "boolean" }
      },
      "additionalProperties": false,
      "oneOf": [
        { "required": ["run"] },
        { "required": ["exec"] },
        { "required": ["target"] },
        { "required": ["target_exec"] }
      ]
    }
  }
}
