{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vmlab flow",
  "type": "object",
  "required": ["steps"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "run": { "type": "string", "minLength": 1 },
          "assert": { "type": "string", "minLength": 1 }
        },
        "anyOf": [
          { "required": ["run"] },
          { "required": ["assert"] }
        ]
      }
    }
  },
  "additionalProperties": false
}
