{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vmlab flow",
  "type": "object",
  "required": ["steps"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "workdir": { "type": "string", "minLength": 1 },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "when": { "type": "string" },
          "retries": { "type": "integer", "minimum": 0 },
          "retry_delay": { "type": "string", "minLength": 1 },
          "timeout": { "type": "string", "minLength": 1 },
          "workdir": { "type": "string", "minLength": 1 },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "run": { "type": "string", "minLength": 1 },
          "assert": { "type": "string", "minLength": 1 },
          "sync": { "type": "string", "minLength": 1 },
          "background": { "type": "boolean" },
          "exec": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "install": {
            "type": "object",
            "additionalProperties": { "type": "string", "minLength": 1 },
            "properties": {
              "mac":     { "type": "string" },
              "darwin":  { "type": "string" },
              "linux":   { "type": "string" },
              "windows": { "type": "string" },
              "ios":     { "type": "string" },
              "android": { "type": "string" }
            }
          },
          "artifact": {
            "type": "object",
            "required": ["build"],
            "additionalProperties": false,
            "properties": {
              "src": { "type": "string" },
              "build": {
                "type": "object",
                "additionalProperties": { "type": "string", "minLength": 1 },
                "properties": {
                  "mac":     { "type": "string" },
                  "darwin":  { "type": "string" },
                  "linux":   { "type": "string" },
                  "windows": { "type": "string" },
                  "ios":     { "type": "string" },
                  "android": { "type": "string" }
                }
              },
              "output": {
                "type": "object",
                "additionalProperties": { "type": "string", "minLength": 1 },
                "properties": {
                  "mac":     { "type": "string" },
                  "darwin":  { "type": "string" },
                  "linux":   { "type": "string" },
                  "windows": { "type": "string" },
                  "ios":     { "type": "string" },
                  "android": { "type": "string" }
                }
              },
              "deliver_to": { "type": "string" }
            }
          },
          "gui": {
            "type": "object",
            "required": ["kind"],
            "additionalProperties": false,
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "click",
                  "click-text",
                  "click-at",
                  "type",
                  "hotkey",
                  "screenshot",
                  "observe",
                  "tree",
                  "wait",
                  "approve",
                  "run",
                  "run-flow",
                  "open-url",
                  "context",
                  "capture",
                  "ask",
                  "summarize",
                  "rewrite"
                ]
              },
              "selector": { "type": "string" },
              "text": { "type": "string" },
              "path": { "type": "string" },
              "extra": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "anyOf": [
          { "required": ["run"] },
          { "required": ["assert"] },
          { "required": ["exec"] },
          { "required": ["install"] },
          { "required": ["artifact"] },
          { "required": ["sync"] },
          { "required": ["gui"] }
        ]
      }
    }
  },
  "additionalProperties": false
}
